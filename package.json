{
	"name": "rescript-typesql",
	"version": "0.22.0",
	"description": "ReScript-first SQL code generation and query tooling for PostgreSQL, MySQL, SQLite, libSQL, and D1.",
	"main": "./dist/src/index.js",
	"types": "./dist/src/index.d.ts",
	"bin": {
		"typesql": "./dist/src/cli.js"
	},
	"exports": {
		".": {
			"types": "./dist/src/index.d.ts",
			"default": "./dist/src/index.js"
		},
		"./package.json": "./package.json"
	},
	"files": [
		"dist/src/**",
		"README.md",
		"LICENSE"
	],
	"scripts": {
		"clean": "shx rm -rf dist",
		"build": "npm run clean && tsc",
		"watch": "tsc -w",
		"pretest": "npm run build",
		"test": "mocha --enable-source-maps dist/tests/**/*.js",
		"test:built": "mocha --exit --enable-source-maps dist/tests/**/*.js",
		"test:rescript": "mocha --enable-source-maps dist/tests/rescript/*.js",
		"test:rescript:built": "mocha --exit --enable-source-maps dist/tests/rescript/*.js",
		"test:watch": "mocha --enable-source-maps dist/tests/**/*.js --watch --watch-files **/*.js",
		"test:rescript:watch": "mocha --enable-source-maps dist/tests/rescript/*.js --watch --watch-files dist/tests/rescript/**/*.js",
		"antlr4ts": "antlr4ts -Xexact-output-dir -o ./parser/ ./grammar/*.g4",
		"ci:setup-db": "node ./scripts/setup-test-databases.mjs",
		"pack:dry-run": "npm pack --dry-run",
		"prepack": "npm run build",
		"gen": "node ./dist/src/cli.js compile",
		"gen-pg": "node ./dist/src/cli.js --config ./tests/postgres-e2e/typesql.json compile"
	},
	"keywords": [
		"rescript",
		"sql",
		"postgresql",
		"mysql",
		"sqlite",
		"libsql",
		"d1",
		"codegen",
		"cli"
	],
	"author": "zth",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/zth/typesql.git"
	},
	"bugs": {
		"url": "https://github.com/zth/typesql/issues"
	},
	"homepage": "https://github.com/zth/typesql#readme",
	"publishConfig": {
		"access": "public"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.4",
		"@cloudflare/workers-types": "^4.20250910.0",
		"@types/better-sqlite3": "^7.6.13",
		"@types/lodash.uniqby": "^4.7.9",
		"@types/mocha": "^10.0.10",
		"@types/node": "^20.19.13",
		"@types/pg": "^8.15.5",
		"@types/pg-copy-streams": "^1.2.5",
		"@types/yargs": "^17.0.33",
		"mocha": "^10.8.2",
		"pg": "^8.16.3",
		"pg-copy-streams": "^6.0.6",
		"prettier": "^3.6.2",
		"rescript": "^12.2.0",
		"rescript-embed-lang": "^0.5.5",
		"shx": "^0.3.4",
		"ts-node": "^10.9.2",
		"typescript": "^5.9.2"
	},
	"dependencies": {
		"@wsporto/typesql-parser": "^0.0.3",
		"better-sqlite3": "^12.2.0",
		"camelcase": "^8.0.0",
		"chokidar": "^3.6.0",
		"code-block-writer": "^13.0.3",
		"dotenv": "^17.2.2",
		"dprint-node": "^1.0.8",
		"fp-ts": "^2.16.11",
		"glob": "^11.0.3",
		"libsql": "^0.4.7",
		"lodash.uniqby": "^4.7.0",
		"moment": "^2.30.1",
		"mysql2": "^3.14.5",
		"neverthrow": "^8.2.0",
		"postgres": "^3.4.7",
		"ts-blank-space": "^0.6.2",
		"yargs": "^17.7.2"
	}
}
